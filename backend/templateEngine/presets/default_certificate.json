{
  "name": "Classic Achievement",
  "description": "Default landscape achievement certificate with formal border.",
  "canvas": {
    "width": 1600,
    "height": 1130,
    "backgroundColor": [253, 251, 247]
  },
  "elements": [
    { "id": "outer-border", "type": "rect", "x": 40, "y": 40, "width": 1520, "height": 1050, "outline": [176, 141, 87], "outlineWidth": 6 },
    { "id": "inner-border", "type": "rect", "x": 60, "y": 60, "width": 1480, "height": 1010, "outline": [176, 141, 87], "outlineWidth": 2 },
    { "id": "title", "type": "text", "text": "CERTIFICATE", "y": 150, "size": 96, "font": "lora-bold", "color": [45, 45, 45], "align": "center" },
    { "id": "subtitle", "type": "text", "text": "OF ACHIEVEMENT", "y": 265, "size": 40, "font": "lora-bold", "color": [176, 141, 87], "align": "center" },
    { "id": "presented-to", "type": "text", "text": "This certificate is proudly presented to", "y": 400, "size": 32, "font": "arial", "color": [90, 90, 90], "align": "center" },
    { "id": "recipient", "type": "text", "text": "{RECIPIENT_NAME}", "y": 470, "size": 92, "font": "lora-bold", "color": [45, 45, 45], "align": "center", "maxWidth": 1300 },
    { "id": "name-rule", "type": "line", "x1": 400, "y1": 600, "x2": 1200, "y2": 600, "color": [176, 141, 87], "width": 3 },
    { "id": "reason", "type": "text", "text": "for outstanding performance in {EVENT_NAME}", "y": 650, "size": 34, "font": "arial", "color": [90, 90, 90], "align": "center", "maxWidth": 1300 },
    { "id": "date", "type": "text", "text": "Awarded on {ISSUE_DATE}", "y": 760, "size": 28, "font": "arial", "color": [90, 90, 90], "align": "center" },
    { "id": "sig-rule", "type": "line", "x1": 1050, "y1": 950, "x2": 1400, "y2": 950, "color": [90, 90, 90], "width": 2 },
    { "id": "sig-label", "type": "text", "text": "{SIGNATORY_NAME}, {SIGNATORY_TITLE}", "x": 1225, "y": 965, "size": 24, "font": "arial", "color": [90, 90, 90], "align": "center" },
    { "id": "verify-qr", "type": "qr", "data": "{VERIFY_URL}", "x": 120, "y": 870, "size": 160 }
  ]
}
