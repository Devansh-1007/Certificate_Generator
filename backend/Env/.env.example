# Copy to Env/.env and fill in. Never commit the real .env.

# ---- Auth ----
JWT_SECRET=long-random-string-change-me
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-strong-password
# bootstrap-only static admin token (optional, works before any admin login)
ADMIN_TOKEN=any-long-random-string
ADMIN=admin

BASE_URL=http://localhost:5000

# ---- MySQL (local install or Docker) ----
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASS=your-mysql-password
MYSQL_DB=certificate
MYSQL_PORT=3306

# ---- Asset paths (relative to backend/) ----
BASE_CERT_PATH=Templates/Images/certificates.png
BASE_IDCARD_PATH=Templates/Images/idCard.png
FONT_PATH=Templates/Fonts/Lora-Bold.ttf
ALL_CERT_IMG_PATH=All_Certificates/Images
ALL_CERT_PDF_PATH=All_Certificates/Pdfs
ALL_ID_IMG_PATH=All_IdCards/Images
ALL_ID_PDF_PATH=All_IdCards/Pdfs

# ---- Object storage: Cloudflare R2 (S3-compatible) ----
# R2 dashboard -> your bucket -> "S3 API" shows the endpoint;
# create an API token (Object Read & Write) for the key pair.
BUCKET=certificate-generator
S3_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_REGION=auto

# ---- AI designer ----
# Free options: provider=openai + Groq or Gemini (free-tier keys), or provider=ollama (fully local).
LLM_PROVIDER=openai
LLM_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=your-free-groq-key
# Gemini instead: OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  LLM_MODEL=gemini-2.0-flash
# Anthropic:      LLM_PROVIDER=anthropic  ANTHROPIC_API_KEY=...
# Local/offline:  LLM_PROVIDER=ollama  LLM_MODEL=llama3.1  OLLAMA_URL=http://localhost:11434
